{
  "name": "inventory-pos/api",
  "description": "Inventory & POS System API",
  "type": "project",
  "require": {
    "php": "^8.1",
    "firebase/php-jwt": "^6.10",
    "ramsey/uuid": "^4.7",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "models/Model.php",
      "config/database.php",
      "config/jwt.php",
      "utils/Response.php",
      "utils/Validator.php"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "@composer dump-autoload"
    ]
  }
}
